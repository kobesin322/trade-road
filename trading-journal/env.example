# Supabase (Project: TradeRoad → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only: never expose to the browser (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Postgres connection for Drizzle (Settings → Database → Connection string → URI)
# Prefer Transaction pooler + sslmode=require for serverless.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Used in magic links and sign-up redirects (your deployed origin or http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
